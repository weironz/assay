# ===== 生产环境变量模板 =====
# 复制为 .env 并填入真实值后再部署：cp .env.prod.example .env

# 对外访问地址（浏览器访问的域名/IP，含协议与端口）
# 例：http://192.168.1.10:8088 或 https://tickets.example.com
PUBLIC_URL=http://localhost:8088
WEB_PORT=8088

# Docker Hub 镜像版本（默认 latest，推荐 1.0.0）
IMAGE_TAG=latest

# PostgreSQL（务必改强密码）
POSTGRES_USER=assay
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=assay

# 对象存储 RustFS（务必改强密钥）
S3_BUCKET=assay-attachments
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME_access_key
S3_SECRET_KEY=CHANGE_ME_secret_key
S3_FORCE_PATH_STYLE=true

# 认证（务必改成长随机串：openssl rand -base64 32）
AUTH_SECRET=CHANGE_ME_long_random_secret

# 初始管理员（首次启动自动创建，登录后请改密码）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_NAME=系统管理员

# 邮件通知（可选，配置 SMTP_HOST 后启用；不配则只发站内信）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=工单系统 <no-reply@example.com>
