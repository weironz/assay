# ===== 通用 =====
NODE_ENV=development

# ===== PostgreSQL =====
POSTGRES_USER=assay
POSTGRES_PASSWORD=assay_dev_pwd
POSTGRES_DB=assay
POSTGRES_PORT=5432
# api 容器内连接串（host 用服务名 postgres）
DATABASE_URL=postgresql://assay:assay_dev_pwd@postgres:5432/assay?schema=public

# ===== Redis（会话 + BullMQ）=====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===== 对象存储（StorageService）=====
# 可选 local | s3 ；s3 指向 RustFS
STORAGE_DRIVER=s3
STORAGE_LOCAL_DIR=/data/attachments
S3_ENDPOINT=http://rustfs:9000
S3_REGION=us-east-1
S3_BUCKET=assay-attachments
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin_dev_pwd
S3_FORCE_PATH_STYLE=true

# ===== 认证（better-auth）=====
AUTH_SECRET=change_me_in_prod_please_use_long_random_string
AUTH_BASE_URL=http://localhost:3000
AUTH_TRUST_ORIGINS=http://localhost:5173
# 启动时自动创建的管理员账号
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
ADMIN_NAME=系统管理员

# ===== 端口 =====
API_PORT=3000
WEB_PORT=5173
ADMINER_PORT=8080
# 注意：若主机 9000/9001 已被其他 RustFS/MinIO 占用，改成空闲端口即可（内部走 rustfs:9000 不受影响）
RUSTFS_PORT=9100
RUSTFS_CONSOLE_PORT=9101

# ===== 前端 =====
VITE_API_BASE_URL=http://localhost:3000
